# .env.example
# 이 파일을 복사해서 .env 로 저장 후 키를 입력하세요.
# 키 발급: https://console.groq.com -> API Keys

GROQ_API_KEY=gsk_여기에_키_입력

# ── 선택 설정 ─────────────────────────────────────────────
CHUNK_SECONDS=20
CHANNELS=2
SOURCE_LANG=en
TARGET_LANG=ko

# Whisper STT 모델
# whisper-large-v3       : 빠름
# whisper-large-v3-turbo : 억양에 강함 (권장)
WHISPER_MODEL=whisper-large-v3-turbo

# 번역 LLM 모델
# llama-3.1-8b-instant    : 빠름, 가벼움
# llama-3.3-70b-versatile : 고품질 번역 (권장)
LLM_MODEL=llama-3.3-70b-versatile

# 무음 감지 임계값 (0.0 ~ 1.0)
# 높을수록 더 큰 소리만 인식 / 낮출수록 작은 소리도 인식
SILENCE_THRESHOLD=0.01

# 오디오 장치 인덱스 (자동 탐지 실패 시에만 설정)
# LOOPBACK_DEVICE_INDEX=1
